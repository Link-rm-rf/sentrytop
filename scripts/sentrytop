#!/usr/bin/env bash

# SentryTop Data Pipeline
# Collector (C) -> Correlator (Java) -> TUI (Python)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

COLLECTOR_BIN="$(readlink -f "$PROJECT_ROOT/collector/sentry_collector")"
ENGINE_JAR=$(ls "$PROJECT_ROOT/engine/target"/sentry-engine-*.jar | head -n 1)
ASSETS_DIR="$(readlink -f "$PROJECT_ROOT/assets")"

if [ -z "$ENGINE_JAR" ]; then
    echo "[!] Engine JAR not found in $PROJECT_ROOT/engine/target/"
    exit 1
fi

# Build if missing
if [ ! -f "$COLLECTOR_BIN" ]; then
    echo "[!] Collector binary not found. Building..."
    (cd "$PROJECT_ROOT/collector" && make)
fi

# Locate Java
JAVA_BIN=$(command -v java || echo "/usr/bin/java")
if [ ! -x "$JAVA_BIN" ]; then
    echo "[!] Java not found. Please install OpenJDK 21."
    exit 1
fi

# Locate stdbuf
STDBUF_BIN=$(command -v stdbuf || echo "")

# Run the pipeline with line buffering to ensure real-time UI updates
cd "$PROJECT_ROOT"
if [ -n "$STDBUF_BIN" ]; then
    "$COLLECTOR_BIN" 1 | "$STDBUF_BIN" -oL "$JAVA_BIN" -jar "$ENGINE_JAR"
else
    "$COLLECTOR_BIN" 1 | "$JAVA_BIN" -jar "$ENGINE_JAR"
fi
