#!/usr/bin/env bash

# SentryTop Data Pipeline
# Collector (C) -> Correlator (Java) -> TUI (Python)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

COLLECTOR_BIN="$PROJECT_ROOT/collector/sentry_collector"
ENGINE_JAR="$PROJECT_ROOT/engine/target/sentry-engine-1.0.jar"
ASSETS_DIR="$PROJECT_ROOT/assets"

# Build if missing
if [ ! -f "$COLLECTOR_BIN" ]; then
    echo "[!] Collector binary not found. Building..."
    (cd "$PROJECT_ROOT/collector" && make)
fi

# Run the pipeline with line buffering to ensure real-time UI updates
cd "$PROJECT_ROOT"
$COLLECTOR_BIN 1 | stdbuf -oL java -jar "$ENGINE_JAR"
